# mt5_service/service.env  — copy to service.env (git-ignored) and fill in.
# These are read by start_all.bat and passed to mt5_service.py / cloudflared.

# Shared secret. The Research Ballot app must send this as the x-api-key header
# (set the SAME value as MT5_SERVICE_KEY in the Ballot app's Vercel env).
MT5_SERVICE_KEY=replace-with-a-long-random-string

# Local port the bridge binds (127.0.0.1). Default 8765.
MT5_SERVICE_PORT=8765

# Cloudflare named tunnel name (from `cloudflared tunnel create <name>`).
TUNNEL_NAME=mt5-bridge

# The stable public hostname you routed to the tunnel (https://...).
# This is what the Ballot app uses as MT5_SERVICE_URL.
PUBLIC_URL=https://mt5.example.com
