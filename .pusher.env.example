# ── Pusher credentials (your Windows PC) ─────────────────────────────────
# Copy this file to ".pusher.env" (git-ignored) and fill in real values.
#
# Use a fine-grained PAT scoped to ONLY this repo with Contents: Read AND Write.

GH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx
GH_REPO=your-org/century-dashboard
GH_BRANCH=snapshot
PUSH_INTERVAL=60
