# ── Streamlit Cloud secrets ──────────────────────────────────────────────
# Paste these into: Streamlit Cloud → your app → Settings → Secrets
# (or copy this file to .streamlit/secrets.toml for local snapshot testing — it is git-ignored)
#
# The frontend reads the snapshot from a PRIVATE GitHub repo using this token.
# Use a fine-grained PAT scoped to ONLY this repo with Contents: Read.

GH_REPO   = "your-org/century-dashboard"
GH_TOKEN  = "github_pat_xxxxxxxxxxxxxxxxxxxxxxxx"
GH_BRANCH = "snapshot"
